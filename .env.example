# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRATION_HOURS=24

# Supabase PostgreSQL (connection pooling — port 6543 recommended on Scalingo)
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Direct connection (migrations / local dev only)
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# Scalingo sets PORT automatically in production
PORT=5001

# Mistral AI (lead extraction from call transcripts)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Optional: OpenAI for Whisper STT + neural TTS (voice calls)
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova
VOICE_LANGUAGE=fr

# Twilio (production phone calls)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_DEFAULT_TENANT_ID=your-tenant-uuid
TWILIO_AI_PHONE_NUMBER=+33159169691
TWILIO_AI_PHONE_DISPLAY=+33 1 59 16 96 91

# Optional: require X-Webhook-Secret header on webhooks
WEBHOOK_SECRET=