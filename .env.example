# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret
JWT_EXPIRATION_HOURS=24

# Supabase PostgreSQL — projet PilotCore (ref xtqhyvvsjoyscdclyaxp, eu-central-1)
# Supavisor pooler (IPv4, transaction mode) — OBLIGATOIRE sur Scalingo (pas d'IPv6, host direct db.* est IPv6-only)
DATABASE_URL=postgresql://postgres.xtqhyvvsjoyscdclyaxp:YOUR_DB_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# Direct connection (migrations / local dev only — IPv6-only, ne marche pas depuis Scalingo)
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.xtqhyvvsjoyscdclyaxp.supabase.co:5432/postgres

# Google Places — autocomplétion des champs ville (annuaire, inscription, paramètres).
# Restreindre la clé par referrer (www.pilotcore.fr) dans Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# Google Search Console (OAuth — /admin/gsc)
# Redirect URI à autoriser : https://www.pilotcore.fr/admin/gsc/callback
GOOGLE_GSC_CLIENT_ID=
GOOGLE_GSC_CLIENT_SECRET=

# Scalingo (production)
# Canonical public URL (webhooks Twilio/Stripe, liens e-mail). Sans slash final.
PUBLIC_BASE_URL=https://www.pilotcore.fr
PREFERRED_URL_SCHEME=https

# Mistral AI (lead extraction from call transcripts)
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_MODEL=mistral-small-latest

# Optional: OpenAI for Whisper STT + neural TTS (voice calls)
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova
VOICE_LANGUAGE=fr

# Twilio (production phone calls)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_DEFAULT_TENANT_ID=your-tenant-uuid
TWILIO_AI_PHONE_NUMBER=+33159169691
TWILIO_AI_PHONE_DISPLAY=+33 1 59 16 96 91
# Sender number for outbound SMS (signed-devis link). Falls back to TWILIO_AI_PHONE_NUMBER.
TWILIO_SMS_FROM=

# --- Numéro IA dédié par tenant (multi-tenant) ---
# En multi-tenant, chaque plombier a besoin de SON propre numéro : un appel ne
# porte pas d'identifiant, seul le numéro composé permet de router l'appel vers
# le bon plombier. Quand activé (et Twilio configuré), un numéro est acheté et
# branché sur le webhook voix automatiquement à l'inscription — le plombier n'a
# rien à faire. Mettre à 0 pour désactiver (les tenants partagent alors
# TWILIO_AI_PHONE_NUMBER). NB : nécessite PUBLIC_BASE_URL pour construire l'URL du
# webhook, et un éventuel bundle réglementaire Twilio pour les numéros FR.
TWILIO_AUTO_PROVISION_NUMBERS=1
# Pays (ISO alpha-2) où acheter les numéros, et indicatif régional optionnel.
TWILIO_NUMBER_COUNTRY=FR
TWILIO_NUMBER_AREA_CODE=
# Twilio <Say> voice — Amazon Polly neural for a natural, human tone
# (e.g. Polly.Lea-Neural = FR female, Polly.Remi-Neural = FR male)
TWILIO_VOICE=Polly.Lea-Neural

# Twilio speech-recognition model. "googlev2" is multilingual and understands
# natural French (recommended). Do NOT use "phone_call" for French — that
# enhanced model is English-only and breaks French recognition.
TWILIO_SPEECH_MODEL=googlev2

# Optional: require X-Webhook-Secret header on /webhook/inbound-call (obligatoire en prod)
WEBHOOK_SECRET=generate-a-random-secret

# Validate Twilio webhook signatures (1 = on, recommended in prod). Needs
# TWILIO_AUTH_TOKEN. Set to 0 for local testing without real Twilio calls.
TWILIO_VALIDATE_SIGNATURE=1

# --- Admin console (/admin) — séparé du site vitrine ---
# Le nom d'utilisateur n'est pas secret. En production, définissez ADMIN_PASSWORD
# (le hash par défaut est désactivé hors développement).
ADMIN_USERNAME=PilotCore_Admin
ADMIN_PASSWORD=change-me-strong-password
# Alternative : hash Werkzeug au lieu du mot de passe en clair.
ADMIN_PASSWORD_HASH=

# --- Email (console admin — boîte LWS contact@pilotcore.fr) ---
# Sortant SMTP (LWS : port 465 SSL ou 587 STARTTLS)
SMTP_HOST=mail.pilotcore.fr
SMTP_PORT=465
SMTP_USER=contact@pilotcore.fr
SMTP_PASSWORD=
SMTP_USE_SSL=1
SMTP_USE_TLS=0
EMAIL_FROM=contact@pilotcore.fr
# Entrant IMAP (sync manuelle ou bouton « Sync IMAP » dans /admin/emails)
IMAP_HOST=mail.pilotcore.fr
IMAP_PORT=993
IMAP_USER=contact@pilotcore.fr
IMAP_PASSWORD=
IMAP_USE_SSL=1
IMAP_FOLDER=INBOX
# Alternative entrante : webhook Mailgun/SendGrid → /admin/email/inbound
EMAIL_INBOUND_SECRET=generate-a-random-secret

# Stripe billing (Starter 149 €/mo, Pro 349 €/mo, Premium 699 €/mo).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe Dashboard → Webhooks → https://pilotcore.fr/billing/webhook (obligatoire en live)
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: pre-created Price IDs. If empty, prices are created on the fly.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
# Optional commission on client deposits via Stripe Connect (0 = artisan keeps all).
STRIPE_CONNECT_FEE_PERCENT=0
# Price per call beyond the plan allowance, in euro cents (default 50 = 0,50 €).
CALL_OVERAGE_PRICE_CENTS=50